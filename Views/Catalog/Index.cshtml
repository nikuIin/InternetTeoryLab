@{
    ViewData["Title"] = "Каталог вин";
}

@section Styles {
    <link href="~/styles/aurora.css" rel="stylesheet" />
    <link href="~/styles/filter.css" rel="stylesheet" />
    <link href="~/styles/card.css" rel="stylesheet" />
    <link href="~/styles/articles.css" rel="stylesheet" />
    <style>
        .products__title { font-size: 2.4rem; font-weight: 800; margin: 2rem 0 0; }
        .products__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px; margin-top: 1.5rem; }
        .loading { text-align: center; padding: 3rem; color: var(--text-color-muted); font-size: 1.1rem; }
        .no-results { text-align: center; padding: 3rem; color: var(--text-color-muted); }
        .pagination { display: flex; justify-content: center; gap: 8px; margin: 2rem 0; }
        .pagination button { padding: 8px 16px; border: 1px solid var(--border-color); border-radius: var(--border-radius-sm); background: var(--background-color-white); cursor: pointer; font-size: 1rem; transition: all 0.2s; }
        .pagination button:hover, .pagination button.active { background: var(--primary-color); color: #fff; border-color: var(--primary-color); }
        .pagination button:disabled { opacity: 0.4; cursor: not-allowed; }
        .filter__tag.active { background: var(--primary-color); color: var(--text-color-white); }
        .card__price { font-weight: 700; color: var(--primary-color); margin-top: 6px; font-size: 1.1rem; }
        .card__year { font-size: 0.9rem; color: var(--text-color-muted); }
        .results-count { color: var(--text-color-muted); font-size: 0.98rem; margin-top: 0.5rem; }
        .filter__select { padding: 7px 16px; border: 1px solid var(--border-color-input); border-radius: var(--border-radius-sm); font-size: 1rem; color: var(--text-color); background: var(--background-color-white); outline: none; font-family: inherit; }
        .toast { position: fixed; bottom: 2rem; right: 2rem; background: #222; color: #fff; padding: 14px 24px; border-radius: var(--border-radius-md); z-index: 1000; opacity: 0; transform: translateY(20px); transition: all 0.3s; pointer-events: none; }
        .toast.show { opacity: 1; transform: translateY(0); }
        .toast.success { background: #1a7a3c; }
        .toast.error { background: #b91c1c; }
        .suggestions-container {
            box-shadow: var(--box-shadow-md);
        }
        .suggestion-item {
            padding: 8px 12px;
            cursor: pointer;
            transition: background 0.2s;
            border-bottom: 1px solid var(--border-color-light);
        }
        .suggestion-item:last-child {
            border-bottom: none;
        }
        .suggestion-item:hover {
            background-color: var(--background-color-alt);
        }
    </style>
}

<div class="container">
    <h1 class="products__title">Каталог вин</h1>

    <section class="filter">
        <div class="filter__search">
            <label class="filter__label" for="search-input">Поиск</label>
            <div style="position: relative;">
                <input class="filter__input" id="search-input" placeholder="Поиск по названию, типу..." type="text" autocomplete="off" />
                <div id="suggestions-container" class="suggestions-container" style="display: none; position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid var(--border-color); border-radius: var(--border-radius-sm); z-index: 100; max-height: 300px; overflow-y: auto;">
                </div>
            </div>
        </div>

        <div class="filter__content">
            <div class="filter__group">
                <label class="filter__label">Тип вина</label>
                <div class="filter__tags" id="wine-type-tags">
                </div>
            </div>

            <div class="filter__group">
                <label class="filter__label">Тип винограда</label>
                <div class="filter__tags" id="grape-type-tags">
                </div>
            </div>

            <div class="filter__group">
                <label class="filter__label">Год производства</label>
                <style>
                    .year-input {
                        display: flex;
                        justify-content: center;
                        align-items: center;
                        gap: 2px;
                    }
                </style>
                <div class="filter__tags">
                    <div class="year-input">
                        <p>От</p>
                        <input class="filter__input" type="number" id="year-from" placeholder="От" min="1800" max="2099" style="width:125px;text-align:center;" />
                    </div>
                    <div class="year-input">
                        <p>До</p>
                        <input class="filter__input" type="number" id="year-to" placeholder="До" min="1800" max="2099" style="width:125px;text-align:center;" />
                    </div>
                </div>
            </div>

            <div class="filter__group">
                <label class="filter__label">Сортировать по</label>
                <select id="sort-by" class="filter__select">
                    <option value="default">По умолчанию</option>
                    <option value="price-asc">По цене (возрастанию)</option>
                    <option value="price-desc">По цене (убыванию)</option>
                    <option value="name-asc">По названию (А-Я)</option>
                    <option value="name-desc">По названию (Я-А)</option>
                </select>
            </div>

            <div class="filter__group" style="justify-content:flex-end;">
                <button class="button button-contact" id="reset-filters" style="margin-top:auto;">Сбросить</button>
            </div>
        </div>
    </section>

    <div class="results-count" id="results-count"></div>

    <section class="products">
        <div class="products__grid" id="products-grid">
            <div class="loading">Загрузка каталога...</div>
        </div>
        <div class="pagination" id="pagination"></div>
    </section>
</div>

<div class="toast" id="toast"></div>

@section Scripts {
<script>
// =================== AJAX Каталог ===================
const state = {
    search: '',
    wineType: '',
    grapeType: '',
    yearFrom: '',
    yearTo: '',
    sortBy: 'default',
    page: 1,
    pageSize: 16,
    debounceTimer: null
};

// Показать тост-уведомление
function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    toast.textContent = message;
    toast.className = `toast ${type} show`;
    setTimeout(() => toast.classList.remove('show'), 3000);
}

// AJAX-сценарий 1: Загрузка опций фильтров
async function loadFilterOptions() {
    const res = await fetch('/Catalog/GetFilterOptions');
    const data = await res.json();

    const wineTagsEl = document.getElementById('wine-type-tags');
    const grapeTagsEl = document.getElementById('grape-type-tags');

    wineTagsEl.innerHTML = data.wineTypes.map(t =>
        `<button class="filter__tag" data-value="${t}" data-filter="wineType" type="button">${t}</button>`
    ).join('');

    grapeTagsEl.innerHTML = data.grapeTypes.map(t =>
        `<button class="filter__tag" data-value="${t}" data-filter="grapeType" type="button">${t}</button>`
    ).join('');

    document.getElementById('year-from').placeholder = `От ${data.minYear}`;
    document.getElementById('year-to').placeholder = `До ${data.maxYear}`;

    document.querySelectorAll('.filter__tag').forEach(btn => {
        btn.addEventListener('click', () => {
            const filter = btn.dataset.filter;
            const value = btn.dataset.value;
            const isActive = btn.classList.contains('active');

            btn.closest('.filter__tags').querySelectorAll('.filter__tag').forEach(b => b.classList.remove('active'));

            if (!isActive) {
                btn.classList.add('active');
                state[filter] = value;
            } else {
                state[filter] = '';
            }
            state.page = 1;
            loadWines();
        });
    });
}

// AJAX-сценарий 2 & 3: Фильтрация и поиск
async function loadWines() {
    const grid = document.getElementById('products-grid');
    grid.innerHTML = '<div class="loading">Загрузка...</div>';

    const params = new URLSearchParams();
    if (state.search)   params.set('search', state.search);
    if (state.wineType) params.set('wineType', state.wineType);
    if (state.grapeType) params.set('grapeType', state.grapeType);
    if (state.yearFrom) params.set('yearFrom', state.yearFrom);
    if (state.yearTo)   params.set('yearTo', state.yearTo);
    params.set('sortBy', state.sortBy);
    params.set('page', state.page);
    params.set('pageSize', state.pageSize);

    try {
        const res = await fetch(`/Catalog/GetWines?${params}`);
        const data = await res.json();

        document.getElementById('results-count').textContent =
            `Найдено: ${data.total} вин`;

        if (data.items.length === 0) {
            grid.innerHTML = '<div class="no-results">Ничего не найдено по выбранным критериям</div>';
            document.getElementById('pagination').innerHTML = '';
            return;
        }

        grid.innerHTML = data.items.map(w => `
            <a class="card" href="/Wine/Details/${w.id}" aria-label="${w.name}">
                <img alt="${w.name}" class="card__img"
                     src="${w.imageUrl || '/img/wine-products/wine-product1.webp'}"
                     onerror="this.src='/img/wine-products/wine-product1.webp'" />
                <p class="card__title">${escapeHtml(w.name)}</p>
                <p class="card__year">${w.year} г.</p>
                <div class="card__tags">
                    <p class="tag tag-red">${escapeHtml(w.grapeType)}</p>
                    <p class="tag tag-green">${escapeHtml(w.wineType)}</p>
                </div>
                <p class="card__price">${w.price.toLocaleString('ru-RU')} ₽</p>
            </a>
        `).join('');

        renderPagination(data.totalPages);
    } catch (err) {
        grid.innerHTML = '<div class="no-results">Ошибка загрузки каталога</div>';
    }
}

function renderPagination(totalPages) {
    const el = document.getElementById('pagination');
    if (totalPages <= 1) { el.innerHTML = ''; return; }

    let html = `<button ${state.page === 1 ? 'disabled' : ''} onclick="goPage(${state.page - 1})">‹</button>`;
    for (let i = 1; i <= totalPages; i++) {
        html += `<button class="${i === state.page ? 'active' : ''}" onclick="goPage(${i})">${i}</button>`;
    }
    html += `<button ${state.page === totalPages ? 'disabled' : ''} onclick="goPage(${state.page + 1})">›</button>`;
    el.innerHTML = html;
}

function goPage(p) {
    state.page = p;
    loadWines();
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

document.getElementById('sort-by').addEventListener('change', e => {
    state.sortBy = e.target.value;
    state.page = 1;
    loadWines();
});

document.getElementById('search-input').addEventListener('input', e => {
    clearTimeout(state.debounceTimer);
    state.debounceTimer = setTimeout(() => {
        state.search = e.target.value.trim();
        state.page = 1;
        loadWines();
    }, 400);
});

document.getElementById('year-from').addEventListener('change', e => {
    state.yearFrom = e.target.value;
    state.page = 1;
    loadWines();
});
document.getElementById('year-to').addEventListener('change', e => {
    state.yearTo = e.target.value;
    state.page = 1;
    loadWines();
});

document.getElementById('reset-filters').addEventListener('click', () => {
    state.search = '';
    state.wineType = '';
    state.grapeType = '';
    state.yearFrom = '';
    state.yearTo = '';
    state.sortBy = 'default';
    state.page = 1;

    document.getElementById('search-input').value = '';
    document.getElementById('year-from').value = '';
    document.getElementById('year-to').value = '';
    document.getElementById('sort-by').value = 'default';
    document.querySelectorAll('.filter__tag.active').forEach(b => b.classList.remove('active'));

    loadWines();
});

// --- Логика подсказок поиска ---
const searchInput = document.getElementById('search-input');
const suggestionsContainer = document.getElementById('suggestions-container');
let suggestionsDebounceTimer;

searchInput.addEventListener('input', () => {
    clearTimeout(suggestionsDebounceTimer);
    const term = searchInput.value.trim();

    if (term.length < 2) {
        suggestionsContainer.style.display = 'none';
        return;
    }

    suggestionsDebounceTimer = setTimeout(async () => {
        try {
            const response = await fetch(`/Catalog/SearchSuggestions?term=${encodeURIComponent(term)}`);
            const suggestions = await response.json();

            if (suggestions.length > 0) {
                suggestionsContainer.innerHTML = suggestions.map(s =>
                    `<div class="suggestion-item" data-id="${s.id}">${escapeHtml(s.name)}</div>`
                ).join('');
                suggestionsContainer.style.display = 'block';

                document.querySelectorAll('.suggestion-item').forEach(item => {
                    item.addEventListener('click', () => {
                        const wineName = item.textContent;
                        searchInput.value = wineName;
                        suggestionsContainer.style.display = 'none';
                        state.search = wineName;
                        state.page = 1;
                        loadWines();
                    });
                });
            } else {
                suggestionsContainer.style.display = 'none';
            }
        } catch (error) {
            console.error('Ошибка загрузки подсказок:', error);
        }
    }, 300);
});

document.addEventListener('click', (e) => {
    if (!searchInput.contains(e.target) && !suggestionsContainer.contains(e.target)) {
        suggestionsContainer.style.display = 'none';
    }
});

function escapeHtml(unsafe) {
    if (!unsafe) return '';
    return unsafe
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
}

// Начальная загрузка
loadFilterOptions();
loadWines();
</script>
}
