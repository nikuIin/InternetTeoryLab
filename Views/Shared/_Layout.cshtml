<!doctype html>
<html data-theme="light" lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Янтарное</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Display:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link href="~/styles/variables.css" rel="stylesheet" />
    <link href="~/styles/base.css" rel="stylesheet" />
    <link href="~/styles/header.css" rel="stylesheet" />
    <link href="~/styles/buttons.css" rel="stylesheet" />
    <link href="~/styles/footer.css" rel="stylesheet" />
    <link href="~/styles/scroll_top.css" rel="stylesheet" />
    @RenderSection("Styles", required: false)
</head>
<body class="body">
    <header class="header">
        <div class="container header__inner">
            <div class="header__left">
                <a href="/" class="header__logo">
                    <p class="header__logo-text">Янтарное</p>
                </a>
                <nav class="header__nav">
                    <a href="/Catalog" class="header__nav-link">Каталог</a>
                    <a href="/about.html" class="header__nav-link">О нас</a>
                    <a href="/articles.html" class="header__nav-link">Статьи</a>
                    <a href="/faq.html" class="header__nav-link">FAQ</a>
                    <a href="/delivery.html" class="header__nav-link">Доставка</a>
                    <a href="/payment.html" class="header__nav-link">Оплата</a>
                </nav>
            </div>
            <div class="header__right">
                <a href="/Cart" class="header__cart-icon" aria-label="Корзина">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                        fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <path d="M16 10a4 4 0 0 1-8 0"></path>
                    </svg>
                </a>
                <a href="/contacts.html" class="button button-contact">Связаться с нами</a>
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container footer__container">
            <div class="footer__info">
                <p>© 2024 Янтарное. Все права защищены.</p>
                <div class="footer__links">
                    <a class="footer__link" href="/privacy.html">Политика конфиденциальности</a>
                    <a class="footer__link" href="/contacts.html">Контакты</a>
                    <a class="footer__link" href="/AddWine">Добавить вино</a>
                </div>
            </div>
        </div>
    </footer>

    <div class="scroll-to-top" id="scrollToTop">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 15l-6-6-6 6" />
        </svg>
    </div>

    <script src="~/scripts/scroll_top.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
