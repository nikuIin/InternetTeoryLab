@model Wine
@{
    ViewData["Title"] = Model.Name;
}

@section Styles {
    <link href="~/styles/aurora.css" rel="stylesheet" />
    <link href="~/styles/card.css" rel="stylesheet" />
    <link href="~/styles/card_detail.css" rel="stylesheet" />
    <link href="~/styles/fullscrean_images.css" rel="stylesheet" />
    <link href="~/styles/wine_description_tabs.css" rel="stylesheet" />
    <style>
        .card-detail__buy-btn { margin-top: 1.5rem; min-width: 200px; }
        .add-toast { position: fixed; bottom: 2rem; right: 2rem; background: #1a7a3c; color: #fff; padding: 14px 24px; border-radius: var(--border-radius-md); z-index: 1000; opacity: 0; transform: translateY(20px); transition: all 0.3s; pointer-events: none; }
        .add-toast.show { opacity: 1; transform: translateY(0); }
        .add-toast.error { background: #b91c1c; }
        .qty-control { display: flex; align-items: center; gap: 12px; margin-top: 1rem; }
        .qty-btn { width: 36px; height: 36px; border: 1px solid var(--border-color); border-radius: 50%; background: var(--background-color-white); font-size: 1.3rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
        .qty-btn:hover { background: var(--primary-color); color: #fff; border-color: var(--primary-color); }
        .qty-value { font-size: 1.1rem; font-weight: 600; min-width: 32px; text-align: center; }
    </style>
}

<div class="container card-detail-container">
    <section class="card-detail">
        <div class="card-detail__image-wrapper">
            <img alt="@Model.Name" class="card-detail__image"
                 src="@(Model.ImageUrl ?? "/img/wine-products/wine-product1.webp")"
                 onerror="this.src='/img/wine-products/wine-product1.webp'" />
        </div>
        <div class="card-detail__info">
            <h1 class="card-detail__title">@Model.Name</h1>
            <div class="card-detail__tags">
                <p class="tag tag-red">@Model.GrapeType</p>
                <p class="tag tag-green">@Model.WineType</p>
                <p class="tag tag-blue">@Model.Year г.</p>
            </div>

            <p style="font-size:1.6rem;font-weight:800;color:var(--primary-color);margin-top:1rem;">
                @Model.Price.ToString("N0") ₽
            </p>
            <p style="color:var(--text-color-muted);margin-top:0.3rem;">
                Алкоголь: @Model.Alcohol%
            </p>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p style="margin-top:1rem;color:var(--text-color-light);">@Model.Description</p>
            }

            <!-- AJAX-сценарий 4: добавление в корзину без обновления страницы -->
            <div class="qty-control">
                <button class="qty-btn" id="qty-minus">−</button>
                <span class="qty-value" id="qty-value">1</span>
                <button class="qty-btn" id="qty-plus">+</button>
            </div>

            <button class="button button-main card-detail__buy-btn" id="add-to-cart-btn">
                Добавить в корзину
            </button>
        </div>
    </section>
</div>

<div class="add-toast" id="add-toast"></div>

@section Scripts {
<script src="~/scripts/wine_description_tabs.js"></script>
<script>
// AJAX-сценарий 4: Добавление в корзину
const wineId = @Model.Id;
let qty = 1;

document.getElementById('qty-minus').addEventListener('click', () => {
    if (qty > 1) { qty--; document.getElementById('qty-value').textContent = qty; }
});
document.getElementById('qty-plus').addEventListener('click', () => {
    qty++;
    document.getElementById('qty-value').textContent = qty;
});

document.getElementById('add-to-cart-btn').addEventListener('click', async () => {
    const btn = document.getElementById('add-to-cart-btn');
    btn.disabled = true;
    btn.textContent = 'Добавляем...';

    try {
        const res = await fetch('/Wine/AddToCart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ wineId, quantity: qty })
        });
        const data = await res.json();

        const toast = document.getElementById('add-toast');
        toast.textContent = data.message;
        toast.className = `add-toast ${data.success ? '' : 'error'} show`;
        setTimeout(() => toast.classList.remove('show'), 3000);

        if (data.success) {
            btn.textContent = '✓ Добавлено в корзину';
            setTimeout(() => {
                btn.textContent = 'Добавить в корзину';
                btn.disabled = false;
            }, 2000);
            // Обновить счётчик в шапке
            updateCartCount();
        } else {
            btn.textContent = 'Добавить в корзину';
            btn.disabled = false;
        }
    } catch {
        btn.textContent = 'Добавить в корзину';
        btn.disabled = false;
    }
});
</script>
}
